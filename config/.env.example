# ============================================================
# DRPI — Environment Variables Template
# 1. Copy this file:  cp config/.env.example config/.env
# 2. Fill in your own keys
# 3. NEVER commit config/.env to git
# ============================================================

# Optional — only needed if using narrative generator
NLP_API_KEY=your_key_here

# Optional — only needed if using Supabase cloud database
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here

# Optional
BM25_INDEX_PATH=./data/BM25.pkl
